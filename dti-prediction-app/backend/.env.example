# MongoDB Connection
MONGODB_URL=mongodb://your_db_user:your_db_password@your_mongodb_host:27017/?tls=true&ssl=true&authSource=admin&retryWrites=true&w=majority
DATABASE_NAME=your_database_name

# Mock Database - It will be set to true when our mongodb server is down to act as a backup.
USE_MOCK_DB=false

# JWT Secret Key
JWT_SECRET_KEY=your_jwt_secret_key_here

# SMTP Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_VERIFICATION_REQUIRED=true
FRONTEND_URL=http://localhost:3000
